{
  "name": "reqlog-express",
  "version": "0.1.0",
  "description": "Express middleware for reqlog HTTP request logger",
  "license": "MIT",
  "keywords": ["express", "http", "request", "logger", "middleware", "debugger", "dashboard", "reqlog"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FirasLatrech/reqlog.git",
    "directory": "packages/express"
  },
  "homepage": "https://github.com/FirasLatrech/reqlog#readme",
  "bugs": {
    "url": "https://github.com/FirasLatrech/reqlog/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "clean": "rm -rf dist",
    "prepack": "bun run clean && bun run build"
  },
  "dependencies": {
    "reqlog-core": "0.1.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": false }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "express": "^4.18.0"
  }
}
