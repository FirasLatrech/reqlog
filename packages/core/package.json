{
  "name": "reqlog-core",
  "version": "0.2.0",
  "description": "Framework-agnostic HTTP request logger engine with live dashboard",
  "license": "MIT",
  "keywords": ["http", "request", "logger", "debugger", "dashboard", "inspector", "middleware", "sse", "devtools"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FirasLatrech/reqlog.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/FirasLatrech/reqlog#readme",
  "bugs": {
    "url": "https://github.com/FirasLatrech/reqlog/issues"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "clean": "rm -rf dist",
    "test": "bun test src/test",
    "prepack": "bun run clean && cd ../dashboard && bun run build && cd ../core && bun run build"
  },
  "optionalDependencies": {
    "open": ">=8.0.3 <9"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/bun": "^1.3.0"
  }
}
